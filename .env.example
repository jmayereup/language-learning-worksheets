# ------------------------------------------------------------------------------
# PocketBase Configuration
# ------------------------------------------------------------------------------
# The URL of the PocketBase backend instance
POCKETBASE_URL=https://blog.teacherjake.com

# Base URL for uploaded files/media
FILES_BASE_URL=https://files.teacherjake.com

# PocketBase Admin/Superuser credentials (used for scripts/migrations)
# WARNING: Do not commit actual credentials to version control.
POCKETBASE_ADMIN_EMAIL=your-admin-email@example.com
POCKETBASE_ADMIN_PASSWORD=your-secure-admin-password

# Path to the PocketBase pb_hooks directory
POCKETBASE_HOOKS_PATH=/opt/pocketbase/pb_hooks

# ------------------------------------------------------------------------------
# Express Server Configuration
# ------------------------------------------------------------------------------
# The port on which the Express server will listen
PORT=3000

# Base path/subpath where the application is served
BASE_PATH=/worksheets

# ------------------------------------------------------------------------------
# AI/API Integrations
# ------------------------------------------------------------------------------
# Gemini API key for worksheets and content generation features
GEMINI_API_KEY=your-gemini-api-key-here
